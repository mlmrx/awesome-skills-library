{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/awesome-skills-library/awesome-skills-library/schema/skill.schema.json",
  "title": "Awesome Skills Library Skill Metadata",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "category",
    "description",
    "use_cases",
    "inputs",
    "outputs",
    "required_tools",
    "permissions",
    "safety_level",
    "risk_tags",
    "compatibility",
    "provenance",
    "license",
    "maintainers",
    "tests"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "category": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "use_cases": { "type": "array", "items": { "type": "string" } },
    "inputs": { "type": "array", "items": { "type": "string" } },
    "outputs": { "type": "array", "items": { "type": "string" } },
    "required_tools": { "type": "array", "items": { "type": "string" } },
    "permissions": { "type": "array", "items": { "type": "string" } },
    "safety_level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "risk_tags": { "type": "array", "items": { "type": "string" } },
    "compatibility": { "type": "object" },
    "provenance": { "type": "object" },
    "license": { "type": "string" },
    "maintainers": { "type": "array", "items": { "type": "string" } },
    "tests": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
