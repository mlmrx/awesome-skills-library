{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/awesome-skills-library/awesome-skills-library/schema/skill.schema.json",
  "title": "Awesome Skills Library Skill Metadata Schema v1",
  "description": "Machine-readable metadata for reusable agent capability packages in Awesome Skills Library.",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "category",
    "description",
    "use_cases",
    "inputs",
    "outputs",
    "required_tools",
    "permissions",
    "safety_level",
    "risk_tags",
    "compatibility",
    "provenance",
    "license",
    "maintainers",
    "tests"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable registry identifier in dot format, for example agent-infra.agentfacts-profile.",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*(?:\\.[a-z0-9]+(?:-[a-z0-9]+)*)+$"
    },
    "name": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "description": "Semantic version for this skill package.",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "category": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "use_cases": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/namedDescription" }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/namedDescription" }
    },
    "required_tools": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "permissions": {
      "type": "object",
      "required": ["network", "filesystem", "code_execution", "external_api", "user_data_access"],
      "properties": {
        "network": { "type": "boolean" },
        "filesystem": { "type": "boolean" },
        "code_execution": { "type": "boolean" },
        "external_api": { "type": "boolean" },
        "user_data_access": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "safety_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "risk_tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "compatibility": {
      "type": "object",
      "required": ["generic_agents", "claude_skills", "chatgpt_skills", "mcp", "nanda_agentfacts"],
      "properties": {
        "generic_agents": { "$ref": "#/$defs/compatibilityStatus" },
        "claude_skills": { "$ref": "#/$defs/compatibilityStatus" },
        "chatgpt_skills": { "$ref": "#/$defs/compatibilityStatus" },
        "mcp": { "$ref": "#/$defs/compatibilityStatus" },
        "nanda_agentfacts": { "$ref": "#/$defs/compatibilityStatus" }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["author", "source", "references"],
      "properties": {
        "author": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "references": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "license": { "type": "string", "minLength": 1 },
    "maintainers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "contact"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "contact": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "compatibilityStatus": {
      "type": "string",
      "enum": ["supported", "experimental", "not_supported", "unknown"]
    },
    "namedDescription": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
